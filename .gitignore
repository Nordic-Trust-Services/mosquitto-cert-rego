# Build artefacts
build/
build-*/
cmake-build-*/
out/

# Object files and libraries
*.o
*.so
*.so.*
*.a
*.d
*.la
*.lo

# CMake
CMakeCache.txt
CMakeFiles/
CMakeScripts/
